{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "desktop-app",
  "version": "0.1.0",
  "identifier": "com.alaat.desktop-app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "desktop-app",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' asset: data: blob: filesystem: https:",
        "connect-src": "'self' ipc: http://ipc.localhost https: wss:",
        "img-src": "'self' asset: data: blob: https:",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self' asset: data: https:",
        "media-src": "'self' data: blob: https:",
        "object-src": "'none'",
        "frame-src": "'none'",
        "base-uri": "'self'",
        "form-action": "'self'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
