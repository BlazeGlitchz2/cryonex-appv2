import { AppLayout } from "@/components/AppLayout";
import { Button } from "@/components/ui/button";
import { Textarea } from "@/components/ui/textarea";
import { Badge } from "@/components/ui/badge";
import { useState } from "react";
import { Sparkles } from "lucide-react";
import { toast } from "sonner";

export default function CodexPage() {
  const [aiPrompt, setAiPrompt] = useState("");
  const [generatedCode, setGeneratedCode] = useState("");
  const [isGenerating, setIsGenerating] = useState(false);
  const [previewHtml, setPreviewHtml] = useState("");

  const handleAIGenerate = async () => {
    if (!aiPrompt.trim()) {
      toast.error("Please enter a prompt");
      return;
    }

    // Check for API key in both frontend and backend env vars
    const apiKey = import.meta.env.VITE_GEMINI_API_KEY || 
                   import.meta.env.VITE_GOOGLE_API_KEY || 
                   import.meta.env.GEMINI_API_KEY || 
                   import.meta.env.GOOGLE_API_KEY;

    if (!apiKey) {
      toast.error("Please configure GEMINI_API_KEY or GOOGLE_API_KEY in the API Keys tab");
      return;
    }

    setIsGenerating(true);

    try {
      const response = await fetch(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash-exp:generateContent?key=${apiKey}`,
        {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            contents: [
              {
                parts: [
                  {
                    text: `You are an expert web developer. Generate a complete, working HTML page based on this request:\n\n${aiPrompt}\n\nProvide ONLY the complete HTML code with inline CSS and JavaScript. Make it beautiful, modern, and fully functional. Include all necessary styling and interactivity.`,
                  },
                ],
              },
            ],
            generationConfig: {
              temperature: 0.7,
              maxOutputTokens: 8192,
            },
          }),
        }
      );

      if (!response.ok) {
        throw new Error(`API Error: ${response.statusText}`);
      }

      const data = await response.json();
      const generatedText = data.candidates?.[0]?.content?.parts?.[0]?.text || "";
      
      // Extract HTML code from markdown code blocks if present
      let htmlCode = generatedText;
      const codeBlockMatch = generatedText.match(/```html(.*?)```/s);
      
      if (codeBlockMatch) {
        htmlCode = codeBlockMatch[1].trim();
      }
      
      setGeneratedCode(htmlCode);
      setPreviewHtml(htmlCode);
      toast.success("HTML generated successfully");
    } catch (error: any) {
      console.error("AI generation error:", error);
      toast.error(error.message || "Failed to generate code");
    } finally {
      setIsGenerating(false);
    }
  };

  return (
    <AppLayout showBackButton>
      <div className="h-full flex flex-col bg-[#0a0a0a]">
        {/* Header */}
        <div className="border-b border-[#1a1a1a] px-6 py-4 flex items-center justify-between shrink-0">
          <div>
            <h1 className="text-2xl font-semibold text-white flex items-center gap-2">
              <Sparkles className="h-6 w-6" />
              Codex
            </h1>
            <p className="text-sm text-[#6b6b6b] mt-1">AI-powered web page generator</p>
          </div>
          <Badge className="bg-purple-500/20 text-purple-400 border-0">
            Gemini
          </Badge>
        </div>

        {/* Two-Panel Layout */}
        <div className="flex-1 flex overflow-hidden">
          {/* Left Panel - AI Code Generator */}
          <div className="w-1/2 border-r border-[#1a1a1a] flex flex-col">
            <div className="p-4 border-b border-[#1a1a1a]">
              <div className="flex items-center gap-2">
                <Sparkles className="h-5 w-5 text-purple-400" />
                <h3 className="text-sm font-semibold text-white">AI Code Generator</h3>
              </div>
            </div>

            <div className="flex-1 p-4 flex flex-col gap-4">
              <div className="flex-1">
                <label className="text-sm font-medium text-white mb-2 block">
                  Describe what you want to build
                </label>
                <Textarea
                  value={aiPrompt}
                  onChange={(e) => setAiPrompt(e.target.value)}
                  placeholder="Example: Create a beautiful landing page for a coffee shop with a hero section, menu, and contact form..."
                  className="min-h-[200px] bg-[#1a1a1a] border-[#2a2a2a] text-white resize-none"
                  onKeyDown={(e) => {
                    if (e.key === "Enter" && e.ctrlKey) {
                      e.preventDefault();
                      handleAIGenerate();
                    }
                  }}
                  disabled={isGenerating}
                />
              </div>

              <Button
                onClick={handleAIGenerate}
                disabled={isGenerating || !aiPrompt.trim()}
                className="w-full bg-white text-black hover:bg-white/90"
              >
                {isGenerating ? (
                  <>
                    <Sparkles className="h-4 w-4 mr-2 animate-spin" />
                    Generating...
                  </>
                ) : (
                  <>
                    <Sparkles className="h-4 w-4 mr-2" />
                    Generate Web Page
                  </>
                )}
              </Button>
              
              <p className="text-xs text-[#6b6b6b] text-center">
                Press Ctrl+Enter to generate
              </p>

              {generatedCode && (
                <div className="flex-1 overflow-hidden">
                  <label className="text-sm font-medium text-white mb-2 block">
                    Generated HTML
                  </label>
                  <Textarea
                    value={generatedCode}
                    readOnly
                    className="min-h-[300px] font-mono text-xs bg-[#1a1a1a] border-[#2a2a2a] text-white resize-none"
                  />
                </div>
              )}
            </div>
          </div>

          {/* Right Panel - Live Preview */}
          <div className="w-1/2 flex flex-col">
            <div className="p-4 border-b border-[#1a1a1a]">
              <h3 className="text-sm font-semibold text-white">Live Preview</h3>
            </div>

            <div className="flex-1 bg-white overflow-auto">
              {previewHtml ? (
                <iframe
                  srcDoc={previewHtml}
                  className="w-full h-full border-0"
                  title="Preview"
                  sandbox="allow-scripts allow-same-origin"
                />
              ) : (
                <div className="h-full flex items-center justify-center text-gray-400">
                  <div className="text-center">
                    <Sparkles className="h-12 w-12 mx-auto mb-4 text-gray-300" />
                    <p className="text-sm">Your generated web page will appear here</p>
                  </div>
                </div>
              )}
            </div>
          </div>
        </div>
      </div>
    </AppLayout>
  );
}